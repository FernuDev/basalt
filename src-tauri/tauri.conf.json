{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Basalt",
  "version": "0.1.3",
  "identifier": "com.fernudev.basalt",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Basalt",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFQURCNTlDMzUxNUY1N0IKUldSNzlSVTFuTFd0YmwxNDkvdTFWZGZFOEQwYWQ5Q2doNFZINytaRlplZ1ZWajU4R1lWZlRWeisK",
      "endpoints": [
        "https://github.com/FernuDev/basalt/releases/latest/download/latest.json"
      ]
    }
  }
}
